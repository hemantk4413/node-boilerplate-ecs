[
  {
    "name": "node-demo",
    "image": "569144120749.dkr.ecr.us-east-1.amazonaws.com/demo-app-staging:latest",
    "cpu": 512,
    "memory": 1024,
    "essential": true,
    "portMappings": [
      {
        "containerPort": 3000,
        "hostPort": 3000,
        "protocol": "tcp"
      }
    ],
    "environment": [{ "name": "VERSION", "value": "1.0" }],
    "secrets": [
        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_HOST::"},
        { "name": "DB_USERNAME","valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_USERNAME::"},
        { "name": "DB_DATABASE","valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_DATABASE::"},
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_PASSWORD::"},
        { "name": "DB_PORT","valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_PORT::"},
        { "name": "DB_REGION", "valueFrom": "arn:aws:secretsmanager:us-west-1:569144120749:secret:ECS-RDS-bZpgOC:DB_REGION::"}
      ]
  }
]
